<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.OpenCray" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/opencray_primary</item>
        <item name="android:colorBackground">@color/black</item>
    </style>

    <style name="OpenCray.TabButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/panel_surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="OpenCray.SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/panel_surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
