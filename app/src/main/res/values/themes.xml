<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.OpenCray" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/opencray_primary</item>
        <item name="colorAccent">@color/opencray_accent</item>
        <item name="android:colorBackground">@color/opencray_background</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:statusBarColor">@color/opencray_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarColor">@color/opencray_background</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="Theme.OpenCray" parent="Base.Theme.OpenCray" />

    <style name="OpenCray.TabButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/tab_button_selector</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tab_text_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="OpenCray.SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_secondary_selector</item>
        <item name="android:elevation">2dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/opencray_ink</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="OpenCray.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_primary_selector</item>
        <item name="android:elevation">4dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="OpenCray.SkillCard" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/skill_card_surface</item>
        <item name="android:elevation">3dp</item>
        <item name="android:minHeight">94dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/opencray_ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OpenCraySettingsFieldTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:textColor">@color/opencray_primary_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OpenCraySettingsFieldHelp">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textColor">@color/opencray_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="OpenCraySettingsOverviewRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/settings_overview_row_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:drawableEnd">@drawable/ic_chevron_right_24</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="android:drawableTint">@color/settings_demo_primary</item>
        <item name="android:focusable">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">@color/settings_demo_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OpenCraySettingsOverviewDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginEnd">20dp</item>
        <item name="android:background">@drawable/settings_overview_divider</item>
    </style>
</resources>
