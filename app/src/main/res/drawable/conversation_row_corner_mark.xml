<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item
        android:gravity="top|start"
        android:height="1dp"
        android:width="18dp">
        <shape>
            <solid android:color="@color/opencray_border" />
        </shape>
    </item>
    <item
        android:gravity="top|start"
        android:height="14dp"
        android:width="1dp">
        <shape>
            <solid android:color="@color/opencray_border" />
        </shape>
    </item>
    <item
        android:gravity="bottom|end"
        android:height="1dp"
        android:width="18dp">
        <shape>
            <solid android:color="@color/opencray_border" />
        </shape>
    </item>
    <item
        android:gravity="bottom|end"
        android:height="14dp"
        android:width="1dp">
        <shape>
            <solid android:color="@color/opencray_border" />
        </shape>
    </item>
</layer-list>
