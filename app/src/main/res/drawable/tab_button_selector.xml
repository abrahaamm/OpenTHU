<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <gradient
                android:angle="0"
                android:endColor="#FFFF7AC8"
                android:startColor="#FF7C3AED" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FFE5D6FF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#F2FFFFFF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/opencray_border" />
        </shape>
    </item>
</selector>
