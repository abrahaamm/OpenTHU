<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:centerColor="@color/opencray_primary"
                android:endColor="@color/opencray_accent"
                android:startColor="@color/opencray_primary_dark"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:drawable="@drawable/hero_pattern"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp" />
</layer-list>
