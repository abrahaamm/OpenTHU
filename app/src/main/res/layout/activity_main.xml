<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/opencray_primary_dark"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_subtitle"
            android:textColor="@color/opencray_muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_surface"
            android:elevation="4dp"
            android:padding="14dp"
            android:textColor="@color/opencray_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/transport_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/opencray_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/chat_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_chat" />

            <Button
                android:id="@+id/planning_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/tab_planning" />

            <Button
                android:id="@+id/settings_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/tab_settings" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/chat_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/chat_shell"
            android:elevation="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/chat_title"
                    android:textColor="@color/opencray_ink"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/chat_subtitle"
                    android:textColor="@color/opencray_muted"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/chat_conversation_list_title"
                    android:textColor="@color/opencray_ink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/conversation_tabs_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <Button
                    android:id="@+id/new_conversation_button"
                    style="@style/OpenCray.SecondaryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/chat_new_conversation" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/chat_history_scroll"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginStart="14dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/chat_history_surface"
                android:elevation="3dp"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:padding="12dp"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/chat_history_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/chat_input_surface"
                android:elevation="8dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <EditText
                    android:id="@+id/chat_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/chat_input_hint"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:minLines="1"
                    android:padding="0dp"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <Button
                    android:id="@+id/chat_send_button"
                    style="@style/OpenCray.PrimaryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/chat_send"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_skills_title"
                    android:textColor="@color/opencray_ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/quick_skills_subtitle"
                    android:textColor="@color/opencray_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/quick_skills_scroll"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginStart="14dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/chat_history_surface"
                android:clipChildren="true"
                android:clipToPadding="true"
                android:fillViewport="false"
                android:overScrollMode="ifContentScrolls"
                android:padding="8dp"
                android:scrollbars="vertical">

                <GridLayout
                    android:id="@+id/quick_skills_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:clipChildren="true"
                    android:clipToPadding="true"
                    android:padding="2dp"
                    android:paddingBottom="10dp"
                    android:useDefaultMargins="false">

                    <Button
                        android:id="@+id/skill_card_1"
                        style="@style/OpenCray.SkillCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="@string/skill_placeholder_1" />

                    <Button
                        android:id="@+id/skill_card_2"
                        style="@style/OpenCray.SkillCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="@string/skill_placeholder_2" />

                    <Button
                        android:id="@+id/skill_card_3"
                        style="@style/OpenCray.SkillCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="@string/skill_placeholder_3" />

                    <Button
                        android:id="@+id/skill_card_4"
                        style="@style/OpenCray.SkillCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="@string/skill_placeholder_4" />
                </GridLayout>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/context_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/onboarding_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/context_summary_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/home_feed_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/context_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/home_quick_actions_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actions_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/actions_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/planning_snapshot_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/planning_schedule_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/planning_alarm_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/planning_todo_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/task_flow_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/run_agent_button"
                    style="@style/OpenCray.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/run_agent_button" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/host_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/host_hint"
                    android:inputType="textUri"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <EditText
                    android:id="@+id/port_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/port_hint"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <CheckBox
                    android:id="@+id/tls_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/tls_label" />

                <Button
                    android:id="@+id/connect_button"
                    style="@style/OpenCray.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/connect_button" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/capability_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/capability_notification_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capability_notification" />

                <CheckBox
                    android:id="@+id/capability_safety_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capability_safety" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/action_feed_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/action_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <Button
                android:id="@+id/action_primary_button"
                style="@style/OpenCray.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/action_primary" />

            <Button
                android:id="@+id/action_secondary_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_secondary" />

            <Button
                android:id="@+id/action_tertiary_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_tertiary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/safety_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/safety_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_runtime_section"
                    android:textColor="@color/opencray_primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/setting_openai_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_openai_key_hint"
                    android:inputType="textPassword"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_llm_model_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_llm_model_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_llm_base_url_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_llm_base_url_hint"
                    android:inputType="textUri"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_user_id_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_user_id_hint"
                    android:padding="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_skill_section"
                    android:textColor="@color/opencray_primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/setting_webvpn_cookie_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_webvpn_cookie_hint"
                    android:inputType="textPassword"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_webvpn_csrf_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_webvpn_csrf_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_campus_file_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_campus_file_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_search_provider_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_search_provider_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_search_endpoint_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_search_endpoint_hint"
                    android:inputType="textUri"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_search_api_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_search_api_key_hint"
                    android:inputType="textPassword"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_search_ttl_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_search_ttl_hint"
                    android:inputType="number"
                    android:padding="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_memory_section"
                    android:textColor="@color/opencray_primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/setting_memory_file_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_memory_file_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_memory_long_ttl_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_memory_long_ttl_hint"
                    android:inputType="number"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_memory_mid_ttl_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_memory_mid_ttl_hint"
                    android:inputType="number"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_memory_short_ttl_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_memory_short_ttl_hint"
                    android:inputType="number"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_memory_half_life_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_memory_half_life_hint"
                    android:inputType="numberDecimal"
                    android:padding="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_device_section"
                    android:textColor="@color/opencray_primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/setting_adb_bin_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_adb_bin_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_adb_serial_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_adb_serial_hint"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/setting_timezone_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_field_surface"
                    android:hint="@string/setting_timezone_hint"
                    android:padding="10dp" />
            </LinearLayout>

            <Button
                android:id="@+id/save_settings_button"
                style="@style/OpenCray.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/connect_button" />

            <Button
                android:id="@+id/test_settings_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_connection_test" />

            <TextView
                android:id="@+id/settings_privacy_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/preference_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/preference_title"
                    android:textColor="@color/opencray_primary_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/preference_subtitle"
                    android:textColor="@color/opencray_muted"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="• 你更偏好白天的校园活动，晚间活动仅在强相关时提醒。"
                            android:textColor="@color/opencray_ink"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/preference_delete_1"
                            style="@style/OpenCray.SecondaryButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:text="×" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="• DDL、考试和课程调整属于高优先级提醒。"
                            android:textColor="@color/opencray_ink"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/preference_delete_2"
                            style="@style/OpenCray.SecondaryButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:text="×" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="• 推荐讲座时优先考虑 AI、系统、移动开发相关主题。"
                            android:textColor="@color/opencray_ink"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/preference_delete_3"
                            style="@style/OpenCray.SecondaryButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:text="×" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/chat_input_surface"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp">

                    <EditText
                        android:id="@+id/preference_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/preference_hint"
                        android:inputType="text"
                        android:maxLines="2"
                        android:minLines="1"
                        android:padding="0dp"
                        android:textColor="@color/opencray_ink"
                        android:textColorHint="@color/opencray_muted" />

                    <Button
                        android:id="@+id/preference_add_button"
                        style="@style/OpenCray.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/preference_add" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/safety_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <Button
                android:id="@+id/approve_button"
                style="@style/OpenCray.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/approve_button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/events_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/events_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
