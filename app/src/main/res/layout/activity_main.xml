<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/opencray_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/opencray_ink"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_subtitle"
            android:textColor="@color/opencray_muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/opencray_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/transport_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/opencray_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/context_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_context" />

            <Button
                android:id="@+id/actions_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/tab_actions" />

            <Button
                android:id="@+id/safety_tab"
                style="@style/OpenCray.TabButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/tab_safety" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/context_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/context_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/context_summary_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/context_feed_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/context_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actions_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/actions_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/goal_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/goal_hint"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <Button
                    android:id="@+id/plan_goal_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/plan_goal_button" />

                <Button
                    android:id="@+id/run_agent_button"
                    style="@style/OpenCray.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/run_agent_button" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/host_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/host_hint"
                    android:inputType="textUri"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <EditText
                    android:id="@+id/port_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/port_hint"
                    android:inputType="number"
                    android:textColor="@color/opencray_ink"
                    android:textColorHint="@color/opencray_muted" />

                <CheckBox
                    android:id="@+id/tls_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/tls_label" />

                <Button
                    android:id="@+id/connect_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/connect_button" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/capability_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/capability_notification_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capability_notification" />

                <CheckBox
                    android:id="@+id/capability_cross_app_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capability_cross_app" />

                <CheckBox
                    android:id="@+id/capability_safety_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capability_safety" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/action_feed_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/action_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/common_apps_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/common_apps_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <Button
                android:id="@+id/action_primary_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/action_primary" />

            <Button
                android:id="@+id/action_secondary_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_secondary" />

            <Button
                android:id="@+id/action_tertiary_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_tertiary" />

            <Button
                android:id="@+id/launch_wechat_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/launch_wechat" />

            <Button
                android:id="@+id/launch_alipay_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launch_alipay" />

            <Button
                android:id="@+id/launch_amap_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launch_amap" />

            <Button
                android:id="@+id/launch_taobao_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launch_taobao" />

            <Button
                android:id="@+id/launch_meituan_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launch_meituan" />

            <Button
                android:id="@+id/launch_qq_button"
                style="@style/OpenCray.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launch_qq" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/safety_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/safety_title"
                android:textColor="@color/opencray_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/safety_feed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />

            <Button
                android:id="@+id/approve_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/approve_button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/events_label"
                android:textColor="@color/opencray_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/events_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/panel_surface"
                android:padding="16dp"
                android:textColor="@color/opencray_ink"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
